# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# ── Cloud provider API keys ────────────────────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── Local vLLM ─────────────────────────────────────────────────────────────
# Set by docker-compose.vllm.yml; override here only for custom setups.
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=
VLLM_API_KEY=token-abc123

# ── HuggingFace token (required to download gated models for vLLM) ─────────
HUGGING_FACE_HUB_TOKEN=
