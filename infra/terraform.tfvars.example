aws_region   = "us-east-1"
project_name = "webpilot"
github_repo  = "your-org/WebPilotv2"   # e.g. "acme/WebPilotv2"

# Optional overrides:
# instance_type         = "t2.micro"
# server_port           = 8000
# task_cpu              = 256
# task_memory           = 512
# allowed_ingress_cidrs = ["203.0.113.10/32"]   # restrict to your IP

# DuckDNS dynamic DNS (optional — leave blank to skip)
# Get your token at https://www.duckdns.org
# duckdns_token     = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# duckdns_subdomain = "webpilot"   # → webpilot.duckdns.org
