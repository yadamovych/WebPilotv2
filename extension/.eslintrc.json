{
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "chrome": "readonly",
    "errorTracker": "writable",
    "safeChrome": "writable",
    "sendMessageSafe": "writable",
    "safeStor": "writable",
    "reportErrorsToBackend": "writable",
    "WebPilotStepUtils": "readonly",
    "WebPilotScripts": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-catch-shadow": "error",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "prefer-const": "warn",
    "no-var": "warn",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "brace-style": ["error", "1tbs"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "semi": ["error", "always"],
    "comma-dangle": ["warn", "always-multiline"],
    "no-trailing-spaces": "warn",
    "indent": ["warn", 2]
  },
  "overrides": [
    {
      "files": ["scripts/**/*.js"],
      "env": {
        "node": true,
        "browser": false,
        "webextensions": false
      },
      "parserOptions": {
        "sourceType": "script"
      }
    },
    {
      "files": ["tests/**/*.js"],
      "env": {
        "node": true,
        "browser": false,
        "webextensions": false
      },
      "parserOptions": {
        "sourceType": "script"
      },
      "rules": {
        "curly": "off",
        "brace-style": "off"
      }
    }
  ]
}
